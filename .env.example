# ─── Required: fill in before running `whoop-mcp auth` ──────────
WHOOP_EMAIL=your@email.com
WHOOP_PASSWORD=your-whoop-password

# ─── Populated automatically by `whoop-mcp auth`. Do NOT edit. ──
WHOOP_IOS_BEARER_TOKEN=
WHOOP_COGNITO_REFRESH_TOKEN=

# ─── Optional: avoids one redundant bootstrap call per session ─────────────
# Get this from `whoop-mcp auth` output (or any captured JWT).
WHOOP_USER_ID=

# ─── Timezone for response timestamps ──────────────────────────────────────
# Whoop returns all timestamps in UTC. The MCP rewrites them with an explicit
# offset so the AI sees clock-correct local times (e.g.,
# "2026-05-25T15:30:00-07:00" instead of "2026-05-25T22:30:00Z").
#
# Resolution chain:
#   1. WHOOP_TIMEZONE (this var) — IANA name like America/Los_Angeles,
#      America/New_York, Europe/London, Asia/Tokyo. Explicit override.
#   2. Auto-detected from your Whoop profile's timezone_offset field —
#      runs on server boot and refreshes hourly. Travelers get
#      auto-updates as their phone moves between zones.
#   3. System TZ — last resort. UTC inside Docker / Fly / Railway, so
#      Tier 2 saves you here if you don't read these docs.
#
# Leave blank to use auto-detect.
WHOOP_TIMEZONE=

# ─── Remote hosting (HTTP transport) ───────────────────────────────────────
# Leave MCP_TRANSPORT unset (or "stdio") for local Claude Desktop / Claude Code.
# Set MCP_TRANSPORT=http to expose the MCP over HTTP for remote clients.
#
#   MCP_TRANSPORT=http
#   MCP_AUTH_TOKEN=<generate with: openssl rand -hex 32>
#   PORT=3000                  # or MCP_HTTP_PORT, default 3000
#   WHOOP_TOKEN_STORE=envfile  # or "memory" for read-only filesystems
#
# ─── Two ways to authenticate against the HTTP server ──────────────────────
# 1. Static bearer (MCP_AUTH_TOKEN) — works with Claude Code (--header) and the
#    Claude Desktop mcp-remote bridge. Always on.
# 2. OAuth 2.1 — required for claude.ai web + the Claude mobile app's custom
#    connectors (they have no bearer-token field). Enable by setting:
#
#      AUTH_PASSWORD=<a password you'll type once when adding the connector>
#      PUBLIC_URL=https://your-app.fly.dev   # your server's public origin (OAuth issuer)
#
#    MCP_AUTH_TOKEN doubles as the JWT signing secret. Leave AUTH_PASSWORD unset
#    to disable the OAuth/web-connector path entirely.
#
# See README → "Remote hosting" for the full deploy walkthrough.
MCP_TRANSPORT=
MCP_AUTH_TOKEN=
AUTH_PASSWORD=
PUBLIC_URL=
